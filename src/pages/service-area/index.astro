---
import DefaultLayout from "@layouts/DefaultLayout.astro";
import Schema from "@components/Schema.astro";
import FreeEstimateCTA from "@components/FreeEstimateCTA.astro";
import { serviceCities } from "@data/serviceArea";
import { contact } from "@data/contact";
import { faLocationDot } from "@fortawesome/free-solid-svg-icons";

const [w, h, , , path] = faLocationDot.icon;
const pinD = Array.isArray(path) ? path.join(" ") : path;
const pinSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${w} ${h}" fill="currentColor" class="size-4 shrink-0 mt-0.5" aria-hidden="true"><path d="${pinD}" /></svg>`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://imaginelandworks.com" },
    { "@type": "ListItem", position: 2, name: "Service Area", item: "https://imaginelandworks.com/service-area" },
  ],
};
---

<DefaultLayout
  title="Land Clearing Service Area — Polk County, FL | Imagine Land Works"
  description="Imagine Land Works serves Lakeland, Auburndale, Winter Haven, Bartow, Plant City, and communities across Polk County, FL. Land clearing, excavation, and site prep. Free estimates."
>
  <Schema slot="head" schema={breadcrumbSchema} />

  <!-- Hero -->
  <section class="bg-base-100 py-20">
    <div class="container mx-auto px-6 max-w-4xl">
      <p class="text-secondary font-heading text-xl uppercase tracking-widest mb-3">
        Where We Work
      </p>
      <h1 class="text-primary font-heading leading-tight mb-6">
        Land Clearing Service Area — Polk County & Central Florida
      </h1>
      <p class="text-base-content/70 text-lg leading-relaxed max-w-2xl mb-8">
        Based in Lakeland, FL, Imagine Land Works runs crews throughout Polk County and into
        neighboring counties. We provide land clearing, excavation, site preparation, demolition,
        and more to residential and commercial customers across central Florida.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/book" class="btn btn-primary btn-lg">Request a Free Estimate</a>
        <a href={`tel:${contact.phone.raw}`} class="btn btn-outline btn-lg">
          Call {contact.phone.display}
        </a>
      </div>
    </div>
  </section>

  <!-- City cards -->
  <section class="bg-base-200 py-20">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-secondary font-heading text-xl uppercase tracking-widest mb-2">
          Cities We Serve
        </p>
        <h2 class="text-primary font-heading leading-tight">
          From Lakeland to Polk County and Beyond
        </h2>
        <p class="text-base-content/70 max-w-xl mx-auto mt-4">
          Select your city below to learn more about our services in your area.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 max-w-6xl mx-auto">
        {serviceCities.map((city) => (
          <a
            href={`/service-area/${city.slug}`}
            class="card bg-base-100 shadow-sm border border-base-300 rounded-2xl hover:shadow-md hover:border-primary/30 transition-all duration-200 no-underline group"
          >
            <div class="card-body p-6 gap-3">
              <div class="flex items-center gap-2 text-accent">
                <Fragment set:html={pinSvg} />
                <span class="font-heading text-primary text-lg group-hover:text-secondary transition-colors duration-200">
                  {city.name}
                </span>
              </div>
              {city.county && (
                <p class="text-xs text-base-content/50 uppercase tracking-wider mb-0">
                  {city.county}
                </p>
              )}
              <p class="text-sm text-base-content/70 leading-relaxed line-clamp-3 mb-0">
                {city.blurb}
              </p>
              <span class="text-sm font-medium text-primary group-hover:text-secondary transition-colors duration-200 mt-auto">
                See services &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Google Map -->
  <section class="bg-base-100 py-20">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="text-center mb-8">
        <p class="text-secondary font-heading text-xl uppercase tracking-widest mb-2">Our Location</p>
        <h2 class="text-primary font-heading leading-tight">Find Us in Lakeland, FL</h2>
        <p class="text-base-content/70 mt-3">
          Based at {contact.address.street}, {contact.address.city}, {contact.address.state} {contact.address.zip}.
          Serving all of Polk County and surrounding areas.
        </p>
      </div>
      <div class="rounded-2xl overflow-hidden shadow-md border border-base-300 aspect-video">
        <iframe
          title="Imagine Land Works location in Lakeland, FL"
          src={`https://maps.google.com/maps?q=${encodeURIComponent(`${contact.address.street}, ${contact.address.city}, ${contact.address.state} ${contact.address.zip}`)}&output=embed&z=13`}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <FreeEstimateCTA
    headline="Not Sure If We Cover Your Area?"
    subheadline="Just Ask — We'll Tell You Straight."
    body="Our crews are based in Lakeland and regularly travel throughout Polk County and into Hillsborough, Highlands, and Hardee counties. If you're in central Florida, there's a good chance we can help."
    ctaLabel="Request a Free Estimate"
    ctaHref="/book"
    phone={contact.phone.display}
    phoneLabel="Call Us Today"
  />
</DefaultLayout>
