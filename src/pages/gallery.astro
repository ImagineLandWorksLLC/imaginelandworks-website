---
import DefaultLayout from "@layouts/DefaultLayout.astro";
import Breadcrumb from "@components/services/Breadcrumb.astro";
import GalleryGrid from "@components/gallery/GalleryGrid.astro";
import GalleryLightbox from "@components/gallery/GalleryLightbox.astro";
import FreeEstimateCTA from "@components/FreeEstimateCTA.astro";
import Schema from "@components/Schema.astro";
import { galleryItems } from "@data/gallery";
import { contact } from "@data/contact";
import { buildBreadcrumbSchema, SITE_URL } from "@utils/schema";

const seoTitle = "Project Gallery | Imagine Land Works, LLC";
const seoDescription =
  "See land clearing, excavation, demolition, and site preparation projects completed by Imagine Land Works across Lakeland and Polk County, FL.";

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home",    item: SITE_URL },
  { name: "Gallery", item: `${SITE_URL}/gallery` },
]);
---

<DefaultLayout title={seoTitle} description={seoDescription}>
  <Schema slot="head" schema={breadcrumbSchema} />

  <section class="bg-base-100 py-16">
    <div class="container mx-auto px-6 text-center max-w-4xl">
      <p class="text-secondary font-heading text-xl uppercase tracking-widest mb-2">
        Our Work
      </p>
      <h1 class="text-primary font-heading leading-tight">
        Project Gallery
      </h1>
      <p class="text-base-content/70 text-lg leading-relaxed max-w-2xl mx-auto mt-4">
        A look at land clearing, excavation, demolition, and site preparation projects across Lakeland and Polk County, FL.
      </p>
    </div>
  </section>

  <Breadcrumb
    items={[
      { label: "Home", href: "/" },
      { label: "Gallery" },
    ]}
  />

  <GalleryGrid items={galleryItems} />
  <GalleryLightbox />

  <FreeEstimateCTA
    headline="Ready to Start Your Own Project?"
    subheadline="No Obligation. No Guesswork."
    body="Whatever your land clearing, excavation, or site prep project looks like, we'll give you a straight, honest estimate, fast."
    ctaLabel="Request a Free Estimate"
    ctaHref="/book"
    phone={contact.phone.display}
    phoneLabel="Call Us Today"
  />
</DefaultLayout>
