---
import DefaultLayout from "@layouts/DefaultLayout.astro";
import { contact } from "@data/contact";
---

<DefaultLayout
  title="Page Not Found | Imagine Land Works"
  description="The page you're looking for doesn't exist. Head back home or get a free estimate for land clearing and excavation in Lakeland, FL."
  noindex={true}
>
  <section
    id="error-section"
    class="bg-base-100 relative"
    style="padding-bottom: clamp(200px, 28vw, 380px);"
  >
    <!-- Content at z-20 — grass (z-10) slides behind this on scroll -->
    <div class="container mx-auto px-6 text-center relative z-20 pt-28 lg:pt-36">
      <p
        class="font-heading text-accent leading-none mb-2"
        style="font-size:clamp(5rem,15vw,10rem);"
      >
        404
      </p>
      <h1 class="font-heading text-primary text-2xl lg:text-4xl uppercase mb-4 leading-snug">
        Uh oh! This page got lost<br class="hidden sm:block" /> amongst all this rough.
      </h1>
      <p class="text-base-content/60 max-w-sm mx-auto mb-10 leading-relaxed">
        We cleared acres of land, but we couldn't find this one. Try heading back, or give us a call
        at{" "}
        <a
          href={`tel:+1${contact.phone.raw}`}
          class="text-primary font-heading hover:text-accent transition-colors"
          >{contact.phone.display}</a
        >.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/" class="btn btn-primary btn-lg">Go Home</a>
        <a href="/services" class="btn btn-outline btn-primary btn-lg">View Services</a>
        <a href="/book" class="btn btn-secondary btn-lg">Get a Free Estimate</a>
      </div>
    </div>

    <!-- Ground fill behind the grass — same colour as footer (bg-primary = #1F3D2B)
         so the gap exposed when the grass shifts up on scroll blends seamlessly -->
    <div
      class="absolute bottom-0 left-0 w-full"
      style="height: 140px; background: #1F3D2B; z-index: 9;"
      aria-hidden="true"
    ></div>

    <!-- Grass scene — z-10 (behind buttons z-20, above ground fill z-9) -->
