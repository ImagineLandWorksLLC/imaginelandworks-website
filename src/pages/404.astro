---
import DefaultLayout from "@layouts/DefaultLayout.astro";
import { contact } from "@data/contact";
---

<DefaultLayout
  title="Page Not Found | Imagine Land Works"
  description="The page you're looking for doesn't exist. Head back home or get a free estimate for land clearing and excavation in Lakeland, FL."
  noindex={true}
>
  <section class="bg-base-100 relative overflow-hidden" style="min-height: 80vh; display: flex; flex-direction: column; justify-content: center;">

    <div class="container mx-auto px-6 text-center pt-20 pb-16 relative z-10">

      <p class="font-heading text-accent text-8xl lg:text-[10rem] leading-none mb-2 drop-shadow-sm">404</p>

      <h1 class="font-heading text-primary text-2xl lg:text-4xl uppercase mb-4 leading-snug">
        Uh oh! This page got lost<br class="hidden sm:block" /> amongst all this rough.
      </h1>

      <p class="text-base-content/60 max-w-sm mx-auto mb-10 leading-relaxed">
        We cleared acres of land, but we couldn't find this one.
        Try heading back, or give us a call at{" "}
        <a
          href={`tel:+1${contact.phone.raw}`}
          class="text-primary font-heading hover:text-accent transition-colors"
        >{contact.phone.display}</a>.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/" class="btn btn-primary btn-lg">Go Home</a>
        <a href="/services" class="btn btn-outline btn-primary btn-lg">View Services</a>
        <a href="/book" class="btn btn-secondary btn-lg">Get a Free Estimate</a>
      </div>
    </div>

    <!-- Cartoon grass scene -->
    <div class="w-full" aria-hidden="true">
      <svg
        viewBox="0 0 1440 320"
        xmlns="http://www.w3.org/2000/svg"
        preserveAspectRatio="none"
        class="w-full block"
        style="height: clamp(180px, 28vw, 340px);"
      >
        <!-- Sky-to-ground gradient background -->
        <defs>
          <linearGradient id="skyGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="oklch(97% 0.01 130)" />
            <stop offset="100%" stop-color="oklch(88% 0.06 130)" />
          </linearGradient>
          <linearGradient id="dirtGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#8B5E3C" />
            <stop offset="100%" stop-color="#6B4226" />
          </linearGradient>
        </defs>

        <!-- Ground fill -->
        <rect x="0" y="240" width="1440" height="80" fill="url(#dirtGrad)" />

        <!-- Rolling ground hill -->
        <path d="M0,260 Q180,210 360,250 Q540,290 720,245 Q900,200 1080,255 Q1260,305 1440,252 L1440,320 L0,320 Z" fill="#5a7a2a" />
        <path d="M0,270 Q200,230 400,265 Q600,300 800,260 Q1000,220 1200,268 Q1350,300 1440,265 L1440,320 L0,320 Z" fill="#4a6e1e" />

        <!-- Back row of tall overgrown grass (short, dense) -->
        <!-- blade clusters left -->
        <g fill="#3d6b15">
          <path d="M30,260 Q28,220 26,200 Q30,225 34,200 Q36,225 38,260 Z" />
          <path d="M55,258 Q52,215 50,190 Q55,218 60,190 Q62,220 65,258 Z" />
          <path d="M85,262 Q83,225 80,205 Q84,228 88,205 Q90,230 92,262 Z" />
          <path d="M115,256 Q112,210 110,188 Q115,215 120,188 Q122,215 125,256 Z" />
          <path d="M148,260 Q145,218 143,198 Q148,222 153,198 Q155,222 157,260 Z" />
        </g>
        <g fill="#5a8a22">
          <path d="M40,260 Q38,230 36,212 Q40,232 44,212 Q46,232 48,260 Z" />
          <path d="M70,258 Q68,222 66,200 Q70,224 74,200 Q76,224 78,258 Z" />
          <path d="M100,262 Q98,228 96,210 Q100,230 104,210 Q106,230 108,262 Z" />
          <path d="M130,256 Q128,216 126,196 Q130,220 134,196 Q136,220 138,256 Z" />
          <path d="M162,260 Q160,224 158,204 Q162,226 166,204 Q168,226 170,260 Z" />
