  <script is:inline>
    (function () {
      const grass = document.getElementById("grass-scene");
      if (!grass) return;

      let ticking = false;

      function update() {
        grass.style.transform = "translateY(-" + window.scrollY * 0.15 + "px)";
        ticking = false;
      }

      window.addEventListener(
        "scroll",
        function () {
          if (!ticking) {
            requestAnimationFrame(update);
            ticking = true;
          }
        },
        { passive: true }
      );
    })();
  </script>
</DefaultLayout>
