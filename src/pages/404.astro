          <path d="M980,266 Q976,238 972,218 Q979,240 986,218 Q989,240 991,266 Z" />
          <path d="M1020,268 Q1016,240 1012,220 Q1019,242 1026,220 Q1029,242 1031,268 Z" />
          <path d="M1060,270 Q1056,242 1052,222 Q1059,244 1066,222 Q1069,244 1071,270 Z" />
          <path d="M1300,268 Q1296,238 1292,218 Q1299,240 1306,218 Q1309,240 1311,268 Z" />
          <path d="M1340,266 Q1336,238 1332,218 Q1339,240 1346,218 Q1349,240 1351,266 Z" />
          <path d="M1380,270 Q1376,242 1372,222 Q1379,244 1386,222 Q1389,244 1391,270 Z" />
          <path d="M1420,268 Q1416,238 1412,218 Q1419,240 1426,218 Q1429,240 1431,268 Z" />
        </g>

        <!-- Foreground dark ground strip -->
        <path d="M0,285 Q360,278 720,282 Q1080,286 1440,280 L1440,320 L0,320 Z" fill="#3d5c12" />
        <path d="M0,295 Q360,290 720,293 Q1080,296 1440,291 L1440,320 L0,320 Z" fill="#2e4a0a" />
      </svg>
    </div>

  </section>
</DefaultLayout>
