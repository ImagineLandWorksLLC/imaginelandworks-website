---
import BaseLayout from "@layouts/BaseLayout.astro";
import Navbar from "@components/NavBar.astro";
import JobberForm from "@components/JobberForm.astro";
---

<BaseLayout
  title="Get a Quote - Imagine Land Works"
  description="Request a free quote or estimate from Imagine Land Works in Lakeland, Florida."
>
  <div class="flex flex-col min-h-screen">
    <header>
      <Navbar />
    </header>
    <main class="flex flex-1 flex-col items-center px-4 py-12">
      <h1 class="text-4xl font-extrabold text-center mb-8">Get a Quote</h1>
      <JobberForm />
    </main>
  </div>
</BaseLayout>
