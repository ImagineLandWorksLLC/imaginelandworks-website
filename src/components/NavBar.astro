---
---

<nav class="navbar bg-base-100 shadow-sm">
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost text-xl flex items-center gap-2">
      <img
        src="/images/ImagineLandWorks.svg"
        alt="ImagineLandWorks Logo"
        class="h-10 w-10"
      />
      ImagineLandWorks
    </a>
  </div>

  <div class="navbar-end">
    <ul class="menu menu-horizontal px-1 hidden lg:flex">
      <li><a href="/">Home</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact Us</a></li>
      <li><a href="/book" class="btn btn-primary btn-sm ml-2">Get Quote</a></li>
    </ul>

    <button id="menu-btn" class="btn btn-ghost lg:hidden" aria-label="Open menu" aria-expanded="false">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
      </svg>
    </button>
  </div>
</nav>

<div id="mobile-menu" class="hidden lg:hidden bg-base-100 border-t border-base-200 shadow-md">
  <ul class="menu p-4 w-full">
    <li><a href="/">Home</a></li>
    <li><a href="/services">Services</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/contact">Contact Us</a></li>
    <li><a href="/book" class="btn btn-primary btn-sm mt-1">Book Now</a></li>
  </ul>
</div>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
