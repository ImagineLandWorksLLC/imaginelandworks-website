---
import { faPhone } from "@fortawesome/free-solid-svg-icons";
import { contact } from "@data/contact";

function iconSvg(icon: typeof faPhone, cls = "size-4") {
  const [w, h, , , path] = icon.icon;
  const d = Array.isArray(path) ? path.join(" ") : path;
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${w} ${h}" fill="currentColor" class="${cls}"><path d="${d}" /></svg>`;
}
---

<nav class="navbar bg-base-100 shadow-sm">

  <!-- Logo -->
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost flex items-center gap-2">
       <img src="/images/original-brand-only.png" alt="Imagine Land Works logo" class="h-10" />
       <span class="font-body text-base leading-tight">land works</span>
    </a>
  </div>

  <!-- Desktop: centered nav links -->
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1">
      <li><a href="/">Home</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact Us</a></li>
    </ul>
  </div>

  <!-- Desktop: phone + CTA | Mobile: hamburger -->
  <div class="navbar-end">

    <div class="hidden lg:flex items-center gap-4">
      <a
        href={`tel:${contact.phone.raw}`}
        class="flex items-center gap-2 text-sm font-medium opacity-60 hover:opacity-100 transition-opacity"
      >
        <Fragment set:html={iconSvg(faPhone, "size-3.5")} />
        {contact.phone.display}
      </a>
      <a href="/book" class="btn btn-primary btn-sm">Get a Quote</a>
    </div>

    <button
      id="menu-btn"
      class="btn btn-ghost lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
      </svg>
    </button>

  </div>
</nav>

<!-- Mobile dropdown -->
<div id="mobile-menu" class="hidden lg:hidden bg-base-100 border-t border-base-200 shadow-md">
  <div class="flex flex-col p-4 gap-1">

    <ul class="menu w-full">
      <li><a href="/">Home</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact Us</a></li>
    </ul>

    <div class="divider my-0"></div>

    <a
      href={`tel:${contact.phone.raw}`}
      class="flex items-center gap-2 px-4 py-2 text-sm font-medium opacity-60 hover:opacity-100 transition-opacity"
    >
      <Fragment set:html={iconSvg(faPhone, "size-3.5")} />
      {contact.phone.display}
    </a>

    <div class="px-4 pt-2 pb-1">
      <a href="/book" class="btn btn-primary btn-sm w-full">Get a Quote</a>
    </div>

  </div>
</div>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
