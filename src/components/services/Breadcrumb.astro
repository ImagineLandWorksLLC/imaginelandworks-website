---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="bg-base-200 border-b border-base-300">
  <div class="container mx-auto px-6 py-3">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm text-base-content/60">
      {items.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="size-3.5 shrink-0 opacity-40"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                clip-rule="evenodd"
              />
            </svg>
          )}
          {item.href ? (
            <a href={item.href} class="hover:text-primary transition-colors">
              {item.label}
            </a>
          ) : (
            <span class="text-base-content/90 font-medium" aria-current="page">
              {item.label}
            </span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>
