---
interface Props {
  eyebrow: string;
  title: string;
  shortDescription: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  eyebrow,
  title,
  shortDescription,
  ctaLabel = "Get a Free Estimate",
  ctaHref = "/book",
} = Astro.props;
---

<section class="bg-primary text-primary-content py-20 lg:py-28 relative overflow-hidden">

  <!-- Decorative rings -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -bottom-32 -right-32 w-125 h-125 rounded-full border border-primary-content/10"></div>
    <div class="absolute -bottom-20 -right-20 w-90 h-90 rounded-full border border-primary-content/8"></div>
    <div class="absolute -top-40 -left-40 w-140 h-140 rounded-full border border-primary-content/8"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10 max-w-3xl">
    <p class="text-secondary font-heading text-xl uppercase tracking-widest mb-4">
      {eyebrow}
    </p>
    <h1 class="text-primary-content font-heading leading-tight mb-6">
      {title}
    </h1>
    <p class="text-primary-content/75 text-lg leading-relaxed mb-10 max-w-2xl">
      {shortDescription}
    </p>
    <a href={ctaHref} class="btn btn-secondary btn-lg shadow-lg">
      {ctaLabel}
    </a>
  </div>
</section>
