---
interface Photo {
  src: string;
  alt: string;
}

interface Props {
  photos?: Photo[];
  serviceName: string;
  eyebrow?: string;
  heading?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  photos,
  serviceName,
  eyebrow = "Our Work",
  heading = "Photos from the Field",
  ctaLabel,
  ctaHref,
} = Astro.props;

const PLACEHOLDER_COUNT = 6;
const hasPhotos = photos && photos.length > 0;
---

<section class="bg-base-200 py-20">
  <div class="container mx-auto px-6">

    <div class="text-center mb-12">
      <p class="text-secondary font-heading text-xl uppercase tracking-widest mb-2">
        {eyebrow}
      </p>
      <h2 class="text-primary font-heading">{heading}</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {hasPhotos ? (
        photos.map((photo) => (
          <div class="overflow-hidden rounded-2xl">
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full aspect-4/3 object-cover"
              loading="lazy"
            />
          </div>
        ))
      ) : (
        Array.from({ length: PLACEHOLDER_COUNT }).map(() => (
          <div class="overflow-hidden rounded-2xl">
            <div class="w-full aspect-4/3 bg-base-100 border-2 border-dashed border-base-content/10 flex flex-col items-center justify-center gap-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="size-12 text-base-content/20"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M1.5 6a2.25 2.25 0 012.25-2.25h16.5A2.25 2.25 0 0122.5 6v12a2.25 2.25 0 01-2.25 2.25H3.75A2.25 2.25 0 011.5 18V6zM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0021 18v-1.94l-2.69-2.689a1.5 1.5 0 00-2.12 0l-.88.879.97.97a.75.75 0 11-1.06 1.06l-5.16-5.159a1.5 1.5 0 00-2.12 0L3 16.061zm10.125-7.81a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0z"
                  clip-rule="evenodd"
                />
              </svg>
              <p class="font-heading text-sm uppercase tracking-wider text-base-content/30">
                {serviceName} Photo
              </p>
              <p class="text-xs text-base-content/25">Coming soon</p>
            </div>
          </div>
        ))
      )}
    </div>

    {ctaLabel && ctaHref && (
      <div class="text-center mt-12">
        <a href={ctaHref} class="btn btn-outline btn-primary btn-lg">{ctaLabel}</a>
      </div>
    )}

  </div>
</section>
