---
interface Step {
  title: string;
  description: string;
}

interface Props {
  steps: Step[];
  heading?: string;
}

const { steps, heading = "How We Do It" } = Astro.props;
---

<section class="bg-base-200 py-20">
  <div class="container mx-auto px-6">

    <div class="text-center mb-14">
      <p class="text-secondary font-heading text-xl uppercase tracking-widest mb-2">
        Our Process
      </p>
      <h2 class="text-primary font-heading">{heading}</h2>
    </div>

    <div class="relative grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">

      <!-- Connector line (desktop only) -->
      <div
        class="hidden md:block absolute top-8 left-[calc(16.66%+1rem)] right-[calc(16.66%+1rem)] h-px bg-base-300"
        aria-hidden="true"
      ></div>

      {steps.map((step, i) => (
        <div class="flex flex-col items-center text-center gap-4 relative">

          <!-- Step circle -->
          <div class="relative z-10 flex items-center justify-center w-16 h-16 rounded-full bg-primary text-primary-content font-heading text-2xl shadow-md ring-4 ring-base-200">
            {i + 1}
          </div>

          <h3 class="font-heading text-primary text-xl">{step.title}</h3>
          <p class="text-base-content/70 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
