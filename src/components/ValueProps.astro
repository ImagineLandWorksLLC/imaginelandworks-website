---
import { iconSvg } from "@utils/icons";

export interface ValueProp {
  icon: string;
  title: string;
}

interface Props {
  items: ValueProp[];
}

const { items } = Astro.props;
---

<div class="bg-base-200 border-y border-base-300">
  <div class="container mx-auto px-6 py-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-base-300">
      {items.map((item) => (
        <div class="flex items-center gap-4 px-6 py-5 first:pl-0 last:pr-0">
          <span class="text-accent shrink-0">
            <Fragment set:html={iconSvg(item.icon, "size-7")} />
          </span>
          <span class="font-heading text-primary text-base uppercase tracking-wide leading-tight">
            {item.title}
          </span>
        </div>
      ))}
    </div>
  </div>
</div>
