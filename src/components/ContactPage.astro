function brandIconSvg(key: keyof typeof brandIcons, cls = "size-5") {
  const { viewBox, path } = brandIcons[key];
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="${viewBox}" fill="currentColor" class="${cls}" aria-hidden="true"><path d="${path}" /></svg>`;
}

---

<section class="bg-base-200 py-16 lg:py-24">
  <div class="container mx-auto px-6">

    <!-- Page header -->
    <div class="text-center mb-12">
      <p class="text-secondary font-heading text-xl uppercase tracking-widest mb-2">Reach Out</p>
      <h1 class="text-primary font-heading">Contact Us</h1>
      <p class="text-base-content/70 max-w-xl mx-auto mt-2 mb-0">
        Have a project in mind or questions about our services? We're here to help.
        Reach us by phone, email, or get started online.
      </p>
    </div>

    <!-- Two-column grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">

      <!-- ─── LEFT: Contact Details ─────────────────────────────── -->
      <div class="card bg-base-100 shadow-md rounded-xl">
        <div class="card-body p-8 gap-0">

          <h2 class="font-heading text-primary text-2xl mb-6">Get in Touch</h2>

          <ul class="flex flex-col divide-y divide-base-200">

            <!-- Phone -->
            <li class="py-5 first:pt-0">
              <a
                href={`tel:${contact.phone.raw}`}
                class="flex items-center gap-4 group no-underline"
                aria-label={`Call ${contact.phone.display}`}
              >
                <span class="shrink-0 w-11 h-11 rounded-xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-primary-content transition-colors duration-200">
                  <Fragment set:html={iconSvg(faPhone)} />
                </span>
                <div class="min-w-0">
                  <p class="text-xs uppercase tracking-widest text-base-content/50 mb-0.5">Phone</p>
                  <p class="font-heading text-xl text-primary group-hover:text-secondary transition-colors duration-200 mb-0 truncate">
                    {contact.phone.display}
                  </p>
                </div>
                <span class="badge badge-secondary badge-soft ml-auto shrink-0 text-xs">Click to call</span>
              </a>
            </li>

            <!-- Email -->
            <li class="py-5">
              <a
                href={`mailto:${contact.email}`}
                class="flex items-center gap-4 group no-underline"
                aria-label={`Email ${contact.email}`}
              >
                <span class="shrink-0 w-11 h-11 rounded-xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-primary-content transition-colors duration-200">
                  <Fragment set:html={iconSvg(faEnvelope)} />
                </span>
                <div class="min-w-0">
                  <p class="text-xs uppercase tracking-widest text-base-content/50 mb-0.5">Email</p>
                  <p class="font-heading text-base text-primary group-hover:text-secondary transition-colors duration-200 mb-0 truncate">
                    {contact.email}
                  </p>
                </div>
              </a>
            </li>

            <!-- Service Area -->
            <li class="py-5">
              <div class="flex items-start gap-4">
                <span class="shrink-0 w-11 h-11 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                  <Fragment set:html={iconSvg(faLocationDot)} />
                </span>
                <div>
                  <p class="text-xs uppercase tracking-widest text-base-content/50 mb-0.5">Service Area</p>
                  <p class="font-heading text-xl text-primary mb-0">{contact.address.city}, {contact.address.state}</p>
                  <p class="text-sm text-base-content/60 mt-0.5 mb-0">{contact.address.county} &amp; surrounding areas</p>
                </div>
              </div>
            </li>

            <!-- Hours -->
            <li class="py-5">
              <div class="flex items-start gap-4">
                <span class="shrink-0 w-11 h-11 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                  <Fragment set:html={iconSvg(faClock)} />
                </span>
                <div class="w-full">
                  <p class="text-xs uppercase tracking-widest text-base-content/50 mb-2">Hours of Operation</p>
                  <div class="flex flex-col gap-1.5">
                    {contact.hours.map(({ days, hours }) => (
                      <div class="flex justify-between gap-4 text-sm">
                        <span class="text-base-content/70">{days}</span>
                        <span class={`font-medium ${hours ? "text-base-content" : "text-base-content/40"}`}>
                          {hours ?? "Closed"}
                        </span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </li>

          </ul>

          <!-- Emergency note -->
          <div class="flex items-start gap-3 bg-accent/10 border border-accent/25 rounded-xl px-4 py-3.5 mt-2">
            <span class="shrink-0 text-accent mt-0.5">
              <Fragment set:html={iconSvg(faTriangleExclamation, "size-4")} />
            </span>
            <p class="text-sm text-base-content/80 mb-0 leading-relaxed">
              <span class="font-semibold text-accent">Emergency services available.</span>
              Call us any time for urgent land clearing needs, we'll respond as fast as we can.
            </p>
          </div>

        </div>
      </div>

      <!-- ─── RIGHT: Quick Actions + Social Links ───────────────── -->
      <div class="flex flex-col gap-6">

        <!-- Quick Actions -->
        <div class="card bg-primary text-primary-content shadow-md rounded-xl">
          <div class="card-body p-8 gap-4">

            <div class="mb-2">
              <h2 class="font-heading text-primary-content text-2xl mb-1">Take Action</h2>
              <p class="text-primary-content/60 text-sm mb-0">Get your project started today.</p>
            </div>

            <!-- Call Now -->
            <a
              href={`tel:${contact.phone.raw}`}
              class="btn btn-secondary btn-lg w-full gap-2.5 shadow-sm"
            >
              <Fragment set:html={iconSvg(faPhone, "size-5")} />
              Call Now
            </a>

            <!-- Request a Free Estimate -->
            <a
              href="/book"
              class="btn btn-accent btn-lg w-full gap-2.5 shadow-sm"
            >
              <Fragment set:html={iconSvg(faCalendarCheck, "size-5")} />
              Request a Free Estimate
            </a>

            <!-- Book a Job (Jobber) -->
            <a
              href={contact.jobber.workRequestUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-lg w-full border border-primary-content/30 bg-primary-content/10 text-primary-content hover:bg-primary-content/20 hover:border-primary-content/50 gap-2.5 shadow-sm"
            >
              Book a Job
            </a>

            <!-- Text Us -->
            <a
              href={`sms:${contact.phone.raw}`}
              class="btn btn-ghost btn-lg w-full text-primary-content/70 hover:text-primary-content hover:bg-primary-content/10 gap-2.5"
            >
              <Fragment set:html={iconSvg(faCommentDots, "size-5")} />
              Text Us
            </a>

          </div>
        </div>

        <!-- Social Links -->
        <div class="card bg-base-100 shadow-md rounded-xl">
          <div class="card-body p-8 gap-5">

            <div>
              <h2 class="font-heading text-primary text-2xl mb-1">Follow Us</h2>
              <p class="text-sm text-base-content/60 mb-0">Stay updated with our latest projects and offers.</p>
            </div>

            <div class="grid grid-cols-2 gap-3">
              {contact.social.map(({ key, label, href }) => (
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 rounded-xl border border-base-300 px-4 py-3 hover:border-primary/40 hover:bg-primary/5 transition-all duration-200 no-underline group"
                  aria-label={`${label} — opens in a new tab`}
                >
                  <span class="shrink-0 text-base-content/50 group-hover:text-primary transition-colors duration-200">
                    <Fragment set:html={brandIconSvg(key)} />
                  </span>
                  <span class="text-sm font-medium text-base-content/65 group-hover:text-primary transition-colors duration-200 truncate">
                    {label}
                  </span>
                </a>
              ))}
            </div>

          </div>
        </div>

      </div>
    </div>

    <!-- Google Map -->
    <div class="max-w-5xl mx-auto mt-8">
      <div class="rounded-2xl overflow-hidden shadow-md border border-base-300 aspect-video">
        <iframe
          title={`Imagine Land Works location — ${contact.address.city}, ${contact.address.state}`}
          src={`https://maps.google.com/maps?q=${encodeURIComponent(`${contact.address.street}, ${contact.address.city}, ${contact.address.state} ${contact.address.zip}`)}&output=embed&z=14`}
          style="border:0; width:100%; height:100%;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <p class="text-center text-sm text-base-content/50 mt-3">
        {contact.address.street}, {contact.address.city}, {contact.address.state} {contact.address.zip}
      </p>
    </div>

  </div>
</section>
