---
import { contact } from "@data/contact";

const { clienthubId, formUrl, workRequestUrl } = contact.jobber;
---

<link
  rel="stylesheet"
  href="https://d3ey4dbjkt2f6s.cloudfront.net/assets/external/work_request_embed.css"
  media="screen"
/>

<div class="w-full">
  <div id={clienthubId} class="w-full"></div>
  <Fragment set:html={`<script src="https://d3ey4dbjkt2f6s.cloudfront.net/assets/static_link/work_request_embed_snippet.js" clienthub_id="${clienthubId}" form_url="${formUrl}"></script>`} />
  <noscript>
    <div class="bg-base-200 rounded-xl p-6 text-center">
      <p class="text-base-content/70 mb-4">
        JavaScript is required to load the estimate form.
      </p>
      <a
        href={workRequestUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
      >
        Open Estimate Request Form
      </a>
    </div>
  </noscript>
</div>
