---
import exImg from "@assets/images/Excavator-X1-Transparent.png";

interface Props {
  title: string;
  description: string;
  buttonText?: string;
  buttonHref?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  buttonText = "Get Started",
  buttonHref = "#",
  imageAlt = "Hero image",
} = Astro.props;
---

<section
  class="relative overflow-hidden bg-gradient-to-br from-base-200 to-base-100"
>
  <div class="container mx-auto">
    <div
      class="flex flex-col lg:flex-row lg:items-center lg:gap-16 lg:px-6 lg:py-24"
    >
      <!-- IMAGE — left on desktop; z-20 on mobile so it sits in front of the bg panel -->
      <div
        class="flex-1 flex justify-center pt-10 lg:pt-0 px-6 lg:px-0 relative z-20 lg:z-auto"
      >
        <img
          src={exImg.src}
          alt={imageAlt}
          class="w-full max-w-sm lg:w-130 lg:max-w-none drop-shadow-2xl rounded-xl
                 lg:translate-x-6 lg:-translate-y-4"
        />
      </div>

      <!-- TEXT — no z-index on this wrapper so it doesn't form a stacking context -->
      <div class="flex-1 relative -mt-12 lg:mt-0 rounded-t-3xl lg:rounded-none">
        <!-- Background panel: z-10 (behind image z-20), hidden on desktop -->
        <div
          class="absolute inset-0 bg-base-100/90 backdrop-blur-sm rounded-t-3xl z-10 lg:hidden"
        ></div>

        <!-- Text content: z-30 (above image z-20), normal flow on desktop -->
        <div
          class="relative z-30 lg:z-auto space-y-6 px-8 pt-8 pb-16 lg:px-0 lg:pt-0 lg:pb-0"
        >
          <h1 class="text-6xl font-extrabold leading-tight">{title}</h1>

          <p class="text-lg text-base-content/80 max-w-lg">
            {description}
          </p>

          <a href={buttonHref} class="btn btn-primary btn-lg mt-4">{buttonText}</a>
        </div>
      </div>
    </div>
  </div>
</section>
