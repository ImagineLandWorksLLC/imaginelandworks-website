---
import exImg from "@assets/images/Excavator-X1-Transparent.png";
---

<section
  class="relative overflow-hidden bg-gradient-to-br from-base-200 to-base-100"
>
  <div class="container mx-auto">
    <div
      class="flex flex-col lg:flex-row lg:items-center lg:gap-16 lg:px-6 lg:py-24"
    >
      <!-- IMAGE — left on desktop, top (full-bleed) on mobile -->
      <div class="flex-1 flex justify-center pt-10 lg:pt-0 px-6 lg:px-0">
        <img
          src={exImg.src}
          alt="Excavator X1 hero image"
          class="w-full max-w-sm lg:w-130 lg:max-w-none drop-shadow-2xl rounded-xl
                 lg:translate-x-6 lg:-translate-y-4"
        />
      </div>

      <!-- TEXT — right on desktop, overlays image bottom on mobile -->
      <div
        class="flex-1 space-y-6 relative z-10
               -mt-12 lg:mt-0
               bg-base-100/90 backdrop-blur-sm rounded-t-3xl px-8 pt-8 pb-16
               lg:bg-transparent lg:backdrop-blur-none lg:rounded-none lg:px-0 lg:pt-0 lg:pb-0"
      >
        <h1 class="text-6xl font-extrabold leading-tight">Hello there</h1>

        <p class="text-lg text-base-content/80 max-w-lg">
          Provident cupiditate voluptatem et in. Quaerat fugiat ut assumenda
          excepturi exercitationem quasi. In deleniti eaque aut repudiandae et a
          id nisi.
        </p>

        <button class="btn btn-primary btn-lg mt-4"> Get Started </button>
      </div>
    </div>
  </div>
</section>
