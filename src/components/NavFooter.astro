---
import FacebookIcon from "../assets/icons/facebook-brands-solid-full.svg";
import InstagramIcon from "../assets/icons/instagram-brands-solid-full.svg";

const year = new Date().getFullYear();
---

<footer class="bg-base-200 text-base-content pt-12 pb-6">
  <div class="container mx-auto px-6">
    <!-- Main Footer Grid -->
    <div class="footer sm:footer-horizontal p-0">
      <!-- Brand -->
      <aside class="flex flex-col gap-4 max-w-sm">
        <img
          src="/images/ImagineLandWorks.svg"
          alt="ImagineLandWorks Logo"
          class="w-40 md:w-60 lg:w-72 h-auto mx-auto"
        />
        <p class="text-sm leading-relaxed">
          Providing creative services since 2026
        </p>
      </aside>

      <!-- Services -->
      <nav>
        <h6 class="footer-title">Services</h6>
        <a class="link link-hover" href="/services">Land Clearing</a>
        <a class="link link-hover" href="/services">Site Prep</a>
        <a class="link link-hover" href="/services">Demo</a>
        <a class="link link-hover" href="/services">Mulching</a>
        <a class="link link-hover" href="/services">Bush Hogging</a>
        <a class="link link-hover" href="/services">Tree Work</a>
        <a class="link link-hover" href="/services">Excavation</a>
        <a class="link link-hover" href="/services">Pond Cleaning</a>
      </nav>

      <!-- Company -->
      <nav>
        <h6 class="footer-title">Company</h6>
        <a class="link link-hover" href="/about">About us</a>
        <a class="link link-hover" href="/contact">Contact</a>
        <a class="link link-hover">Jobs</a>
        <a class="link link-hover">Press kit</a>
      </nav>
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-10 border-t border-base-300 pt-4 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <!-- Left: Copyright -->
      <span class="text-sm opacity-80 leading-none flex items-center">
        © {year} Imagineland Works. All rights reserved.
      </span>

      <!-- Middle: Legal Links -->
      <div class="flex gap-6 text-sm opacity-80 leading-none items-center">
        <a href="/terms" class="link link-hover">Terms of Use</a>
        <a href="/privacy" class="link link-hover">Privacy Policy</a>
      </div>

      <!-- Right: Social Icons -->
      <div class="flex gap-4 items-center">
        <!-- Facebook -->
        <a
          href="https://www.facebook.com/imaginelandworks"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:opacity-80 transition-opacity flex items-center"
        >
          <img
            src={FacebookIcon.src}
            alt="Facebook"
            width="22"
            height="22"
            class="w-5.5 h-5.5"
          />
        </a>

        <!-- Instagram -->
        <a
          href="https://www.instagram.com/imaginelandworks"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:opacity-80 transition-opacity flex items-center"
        >
          <img
            src={InstagramIcon.src}
            alt="Instagram"
            width="22"
            height="22"
            class="w-5.5 h-5.5"
          />
        </a>
      </div>
    </div>
  </div>
</footer>
