---
import FacebookIcon from "../assets/icons/facebook-brands-solid-full.svg";
import InstagramIcon from "../assets/icons/instagram-brands-solid-full.svg";
import { faPhone, faEnvelope, faLocationDot } from "@fortawesome/free-solid-svg-icons";

const year = new Date().getFullYear();

function iconSvg(icon: typeof faPhone, cls = "size-4") {
  const [w, h, , , path] = icon.icon;
  const d = Array.isArray(path) ? path.join(" ") : path;
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${w} ${h}" fill="currentColor" class="${cls}"><path d="${d}" /></svg>`;
}
---

<footer class="bg-primary text-primary-content">

  <!-- Main grid -->
  <div class="container mx-auto px-8 py-20">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr_1fr] lg:gap-8">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1 flex flex-col gap-6">
        <img
          src="/images/ImagineLandWorks.svg"
          alt="ImagineLandWorks"
          class="w-56 h-auto"
        />
        <p class="text-sm leading-relaxed opacity-45 max-w-[28ch]">
          Professional land clearing and site preparation serving the region since 2026.
        </p>
      </div>

      <!-- Clearing & Prep -->
      <nav class="flex flex-col">
        <h6 class="text-secondary text-[0.65rem] font-semibold uppercase tracking-[0.14em] pb-3 mb-4 border-b border-white/10">
          Clearing &amp; Prep
        </h6>
        <div class="flex flex-col gap-2.5">
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/services">Land Clearing</a>
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/services">Site Preparation</a>
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/services">Demolition</a>
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/services">Bush Hogging</a>
        </div>
      </nav>

      <!-- Earthworks -->
      <nav class="flex flex-col">
        <h6 class="text-secondary text-[0.65rem] font-semibold uppercase tracking-[0.14em] pb-3 mb-4 border-b border-white/10">
          Earthworks
        </h6>
        <div class="flex flex-col gap-2.5">
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/services">Excavation</a>
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/services">Mulching</a>
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/services">Tree Work</a>
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/services">Pond Cleaning</a>
        </div>
      </nav>

      <!-- Company -->
      <nav class="flex flex-col">
        <h6 class="text-secondary text-[0.65rem] font-semibold uppercase tracking-[0.14em] pb-3 mb-4 border-b border-white/10">
          Company
        </h6>
        <div class="flex flex-col gap-2.5">
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/about">About Us</a>
          <a class="text-sm opacity-60 hover:opacity-100 transition-opacity" href="/contact">Contact</a>
        </div>
      </nav>

      <!-- Get in touch -->
      <div class="flex flex-col">
        <h6 class="text-secondary text-[0.65rem] font-semibold uppercase tracking-[0.14em] pb-3 mb-4 border-b border-white/10">
          Get in touch
        </h6>
        <div class="flex flex-col gap-4">
          <a
            href="tel:8635550190"
            class="flex items-center gap-3 text-sm opacity-60 hover:opacity-100 transition-opacity no-underline"
          >
            <span class="shrink-0 text-secondary">
              <Fragment set:html={iconSvg(faPhone)} />
            </span>
            (863) 555-0190
          </a>
          <a
            href="mailto:contact@imaginelandworks.com"
            class="flex items-center gap-3 text-sm opacity-60 hover:opacity-100 transition-opacity no-underline"
          >
            <span class="shrink-0 text-secondary">
              <Fragment set:html={iconSvg(faEnvelope)} />
            </span>
            contact@imaginelandworks.com
          </a>
          <div class="flex items-center gap-3 text-sm opacity-60">
            <span class="shrink-0 text-secondary">
              <Fragment set:html={iconSvg(faLocationDot)} />
            </span>
            Lakeland, FL
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/[0.08]">
    <div class="container mx-auto px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">

      <!-- Copyright -->
      <span class="text-xs opacity-35 tracking-wide text-center sm:text-left">
         &copy; {year} Imagine Land Works, LLC
      </span>

      <!-- Legal -->
      <div class="flex gap-6 text-xs opacity-40">
        <a href="/terms" class="hover:opacity-100 transition-opacity">Terms of Use</a>
        <a href="/privacy" class="hover:opacity-100 transition-opacity">Privacy Policy</a>
      </div>

      <!-- Social icons -->
      <div class="flex gap-2.5">
        <a
          href="https://www.facebook.com/imaginelandworks"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="w-9 h-9 rounded-full flex items-center justify-center ring-1 ring-white/20 bg-white/[0.06] hover:bg-white/15 hover:ring-white/35 transition-all duration-200"
        >
          <img src={FacebookIcon.src} alt="" aria-hidden="true" class="w-[1.05rem] h-[1.05rem] invert opacity-65" />
        </a>
        <a
          href="https://www.instagram.com/imaginelandworks"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="w-9 h-9 rounded-full flex items-center justify-center ring-1 ring-white/20 bg-white/[0.06] hover:bg-white/15 hover:ring-white/35 transition-all duration-200"
        >
          <img src={InstagramIcon.src} alt="" aria-hidden="true" class="w-[1.05rem] h-[1.05rem] invert opacity-65" />
        </a>
      </div>

    </div>
  </div>

</footer>
