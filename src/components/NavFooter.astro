---
const year = new Date().getFullYear();
---

<footer class="bg-base-200 text-base-content pt-12 pb-6">
  <div class="container mx-auto px-6">
    <!-- Main Footer Grid -->
    <div class="footer sm:footer-horizontal p-0">
      <!-- Brand -->
      <aside class="flex flex-col gap-3 max-w-xs">
        <img
          src="/images/ImagineLandWorks.svg"
          alt="ImagineLandWorks Logo"
          class="h-12 w-12"
        />
        <p class="text-sm leading-relaxed">
          <span class="font-semibold text-base-content">Imagineland Works</span
          ><br />
          Providing creative services since 2020
        </p>
      </aside>

      <!-- Services -->
      <nav>
        <h6 class="footer-title">Services</h6>
        <a class="link link-hover" href="/services">Branding</a>
        <a class="link link-hover" href="/services">Design</a>
        <a class="link link-hover" href="/services">Marketing</a>
        <a class="link link-hover" href="/services">Advertisement</a>
      </nav>

      <!-- Company -->
      <nav>
        <h6 class="footer-title">Company</h6>
        <a class="link link-hover" href="/about">About us</a>
        <a class="link link-hover" href="/contact">Contact</a>
        <a class="link link-hover">Jobs</a>
        <a class="link link-hover">Press kit</a>
      </nav>

      <!-- Legal -->
      <nav>
        <h6 class="footer-title">Legal</h6>
        <a class="link link-hover" href="/terms">Terms of use</a>
        <a class="link link-hover" href="/privacy">Privacy policy</a>
        <a class="link link-hover" href="/cookies">Cookie policy</a>
      </nav>
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-10 border-t border-base-300 pt-4 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <!-- Left: Copyright -->
      <p class="text-sm opacity-80 leading-none flex items-center">
        © {year} Imagineland Works. All rights reserved.
      </p>

      <!-- Middle: Legal Links -->
      <div class="flex gap-6 text-sm opacity-80 leading-none items-center">
        <a href="/terms" class="link link-hover">Terms of Use</a>
        <a href="/privacy" class="link link-hover">Privacy Policy</a>
        <a href="/sitemap" class="link link-hover">Sitemap</a>
      </div>

      <!-- Right: Social Icons -->
      <div class="flex gap-4 items-center">
        <!-- Facebook -->
        <a
          href="https://www.facebook.com/imaginelandworks"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:opacity-80 transition-opacity flex items-center"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            class="fill-current"
          >
            <path
              d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"
            ></path>
          </svg>
        </a>

        <!-- Instagram -->
        <a
          href="https://www.instagram.com/imaginelandworks"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:opacity-80 transition-opacity flex items-center"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            class="fill-current"
          >
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
