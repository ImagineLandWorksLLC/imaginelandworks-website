---
import FacebookIcon from "../assets/icons/facebook-brands-solid-full.svg";
import InstagramIcon from "../assets/icons/instagram-brands-solid-full.svg";
import { faPhone, faEnvelope, faLocationDot } from "@fortawesome/free-solid-svg-icons";
import { contact } from "@data/contact";

const year = new Date().getFullYear();
const facebookHref = contact.social.find((s) => s.key === "facebook")!.href;
const instagramHref = contact.social.find((s) => s.key === "instagram")!.href;

function iconSvg(icon: typeof faPhone, cls = "size-[1.1rem]") {
  const [w, h, , , path] = icon.icon;
  const d = Array.isArray(path) ? path.join(" ") : path;
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${w} ${h}" fill="currentColor" class="${cls}"><path d="${d}" /></svg>`;
}
---

<footer class="bg-primary text-primary-content border-t border-white/10 text-[15px] md:text-base">

  <!-- Main grid -->
  <div class="container mx-auto px-8 py-24 md:py-28">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr_1.25fr] lg:gap-12">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1 flex flex-col gap-8">
        <img
          src="/images/ImagineLandWorks.svg"
          alt="ImagineLandWorks"
          class="w-64 h-auto"
        />
        <p class="text-sm leading-relaxed opacity-45 max-w-[28ch]">
          Professional land clearing and site preparation serving the region since {contact.founding}.
        </p>
      </div>

      <!-- Clearing & Prep -->
      <nav class="flex flex-col">
        <h6 class="text-secondary text-[0.75rem] font-semibold uppercase tracking-[0.18em] pb-3 mb-5 border-b border-white/10">
          Clearing &amp; Prep
        </h6>
        <div class="flex flex-col gap-3">
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/services">Land Clearing</a>
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/services">Site Preparation</a>
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/services">Demolition</a>
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/services">Bush Hogging</a>
        </div>
      </nav>

      <!-- Earthworks -->
      <nav class="flex flex-col">
        <h6 class="text-secondary text-[0.75rem] font-semibold uppercase tracking-[0.18em] pb-3 mb-5 border-b border-white/10">
          Earthworks
        </h6>
        <div class="flex flex-col gap-3">
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/services">Excavation</a>
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/services">Mulching</a>
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/services">Tree Work</a>
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/services">Pond Cleaning</a>
        </div>
      </nav>

      <!-- Company -->
      <nav class="flex flex-col">
        <h6 class="text-secondary text-[0.75rem] font-semibold uppercase tracking-[0.18em] pb-3 mb-5 border-b border-white/10">
          Company
        </h6>
        <div class="flex flex-col gap-3">
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/about">About Us</a>
          <a class="opacity-60 hover:opacity-100 transition-opacity" href="/contact">Contact</a>
        </div>
      </nav>

      <!-- Get in touch -->
      <div class="flex flex-col">
        <h6 class="text-secondary text-[0.75rem] font-semibold uppercase tracking-[0.18em] pb-3 mb-5 border-b border-white/10">
          Get in touch
        </h6>
        <div class="flex flex-col gap-4">
          <a
            href={`tel:${contact.phone.raw}`}
            class="flex items-center gap-3 opacity-60 hover:opacity-100 transition-opacity no-underline"
          >
            <span class="shrink-0 text-secondary">
              <Fragment set:html={iconSvg(faPhone)} />
            </span>
            {contact.phone.display}
          </a>
          <a
            href={`mailto:${contact.email}`}
            class="flex items-center gap-3 opacity-60 hover:opacity-100 transition-opacity no-underline"
          >
            <span class="shrink-0 text-secondary">
              <Fragment set:html={iconSvg(faEnvelope)} />
            </span>
            {contact.email}
          </a>
          <div class="flex items-center gap-3 opacity-60">
            <span class="shrink-0 text-secondary">
              <Fragment set:html={iconSvg(faLocationDot)} />
            </span>
            {contact.address.city}, {contact.address.state}
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/[0.12]">
    <div class="container mx-auto px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">

      <!-- Copyright -->
      <span class="text-xs opacity-35 tracking-wide text-center sm:text-left">
         &copy; {year} {contact.legalName}
      </span>

      <!-- Legal -->
      <div class="flex gap-6 text-xs opacity-40">
        <a href="/terms" class="hover:opacity-100 transition-opacity">Terms of Use</a>
        <a href="/privacy" class="hover:opacity-100 transition-opacity">Privacy Policy</a>
      </div>

      <!-- Social icons -->
      <div class="flex gap-2.5">
        <a
          href={facebookHref}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="w-9 h-9 rounded-full flex items-center justify-center ring-1 ring-white/20 bg-white/[0.06] hover:bg-white/15 hover:ring-white/35 transition-all duration-200"
        >
          <img src={FacebookIcon.src} alt="" aria-hidden="true" class="w-[1.1rem] h-[1.1rem] invert opacity-65" />
        </a>
        <a
          href={instagramHref}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="w-9 h-9 rounded-full flex items-center justify-center ring-1 ring-white/20 bg-white/[0.06] hover:bg-white/15 hover:ring-white/35 transition-all duration-200"
        >
          <img src={InstagramIcon.src} alt="" aria-hidden="true" class="w-[1.1rem] h-[1.1rem] invert opacity-65" />
        </a>
      </div>

    </div>
  </div>

</footer>
