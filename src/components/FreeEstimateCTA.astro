---
import { faPhone } from "@fortawesome/free-solid-svg-icons";
import { iconFromDef } from "@utils/icons";

interface Props {
  headline: string;
  subheadline: string;
  body: string;
  ctaLabel: string;
  ctaHref: string;
  phone: string;
  phoneLabel: string;
}

const { headline, subheadline, body, ctaLabel, ctaHref, phone, phoneLabel } =
  Astro.props;

const phoneSvg = iconFromDef(faPhone, "size-5 shrink-0");
---

<section class="bg-accent py-20">
  <div class="container mx-auto px-6">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-12">

      <!-- Copy -->
      <div class="flex-1 max-w-2xl space-y-5">
        <p class="text-accent-content/70 font-heading text-xl uppercase tracking-widest">
          {subheadline}
        </p>
        <h2 class="text-accent-content font-heading leading-tight">
          {headline}
        </h2>
        <p class="text-accent-content/80 text-lg leading-relaxed">
          {body}
        </p>
      </div>

      <!-- Actions -->
      <div class="flex flex-col items-start lg:items-end gap-5 shrink-0">
        <a href={ctaHref} class="btn btn-primary btn-lg shadow-lg">
          {ctaLabel}
        </a>

        <!-- Phone box -->
        <a
          href={`tel:${phone.replace(/\D/g, "")}`}
          class="flex items-center gap-3 bg-accent-content/10 border border-accent-content/20
                 rounded-xl px-5 py-4 text-accent-content hover:bg-accent-content/20
                 transition-colors duration-200 no-underline"
        >
          <span class="text-accent-content">
            <Fragment set:html={phoneSvg} />
          </span>
          <div class="flex flex-col leading-tight">
            <span class="text-accent-content/60 text-xs uppercase tracking-wider">
              {phoneLabel}
            </span>
            <span class="font-heading text-2xl">{phone}</span>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>
