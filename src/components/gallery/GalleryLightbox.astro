---
---

<dialog id="gallery-lightbox" class="modal">
  <div class="modal-box max-w-4xl w-11/12 bg-base-100 p-6">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-3 top-3" aria-label="Close">
        &#10005;
      </button>
    </form>

    <div class="relative flex items-center justify-center gap-4 min-h-[50vh]">
      <button
        id="lightbox-prev"
        type="button"
        class="btn btn-circle btn-ghost absolute left-0 z-10"
        aria-label="Previous photo"
      >
        &#8249;
      </button>

      <div id="lightbox-stage" class="flex flex-wrap gap-4 items-center justify-center w-full"></div>

      <button
        id="lightbox-next"
        type="button"
        class="btn btn-circle btn-ghost absolute right-0 z-10"
        aria-label="Next photo"
      >
        &#8250;
      </button>
    </div>

    <p id="lightbox-caption" class="text-center text-base-content/60 text-sm mt-4"></p>
  </div>

  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
